# ============================================
# AI 图像生成工具 - 环境变量配置（可选）
# ============================================
# 复制此文件为 .env 并填写你的 API Key
# 注意：.env 文件不要提交到 Git 仓库！
# 所有 API Key 也可在应用内 ⚙️ 设置面板中配置

# OpenAI API Key
VITE_OPENAI_API_KEY=

# Google Gemini API Key
VITE_GOOGLE_API_KEY=

# 豆包/火山引擎 API Key
VITE_DOUBAO_API_KEY=
